# Required: gpt-4o-mini for annotation generation (only needed to rebuild
# annotations_cache.json; the cache shipped with the repo covers all chunks).
OPENAI_API_KEY=sk-...

# Optional: only needed if you want to compare against Gemini in the research pipeline.
GEMINI_API_KEY=

# Optional / unused by the current code; left here for downstream integrations.
MONGODB_URI=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
